<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/feedback_card_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/new_logo"
                android:contentDescription="@string/app_name"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:text="@string/smishing_ai_assistant"
                android:textColor="@color/smish_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/btnClose"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/close"
                app:tint="@color/smish_text_secondary"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Question -->
        <TextView
            android:text="@string/has_issue_been_solved"
            android:textColor="@color/smish_text_primary"
            android:textSize="15sp"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Yes/No -->
        <RadioGroup
            android:id="@+id/rgSolved"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbYes"
                android:text="@string/yes_smiley"
                android:buttonTint="@color/smish_bot_icon"
                android:textColor="@color/smish_text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioButton
                android:id="@+id/rbNo"
                android:text="@string/no_smiley"
                android:buttonTint="@color/redd"
                android:textColor="@color/smish_text_primary"
                android:layout_marginStart="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <!-- Problems Section -->
        <LinearLayout
            android:id="@+id/problemsLayout"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/experience_problems"
                android:textColor="@color/smish_text_primary"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/cbSolution"
                android:text="@string/problem_solution_not_helpful"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cbRobotic"
                android:text="@string/problem_robotic_replies"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cbSlow"
                android:text="@string/problem_slow_response"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cbWrongWords"
                android:text="@string/problem_wrong_words"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cbRepetitive"
                android:text="@string/problem_repetitive"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/cbUnfriendly"
                android:text="@string/problem_unfriendly"
                android:buttonTint="@color/smish_bot_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/editFeedback"
                android:hint="@string/feedback_hint"
                android:autofillHints="feedback"
                android:textColorHint="@color/smish_text_hint"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:layout_marginTop="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Submit -->
        <Button
            android:id="@+id/btnSubmit"
            android:text="@string/submit_button"
            android:backgroundTint="@color/smish_blue_dark"
            android:textColor="@color/smish_text_on_primary"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
