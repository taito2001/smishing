<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_background"
    android:padding="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="10dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Title -->
            <TextView
                android:id="@+id/exportTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp"
                android:text="Export Detection Report"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/exportSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="Choose Export Format"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Radio options -->
            <RadioGroup
                android:id="@+id/exportFormatGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioPdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="PDF"
                    app:buttonTint="@drawable/radio_tint" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radioCsv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CSV"
                    app:buttonTint="@drawable/radio_tint" />
            </RadioGroup>

            <!-- Primary action -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportNowBtn"
                style="?attr/materialButtonStyle"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="Export Now"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/navy_blue"
                app:cornerRadius="12dp"
                app:elevation="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>