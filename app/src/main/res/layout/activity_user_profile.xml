<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context="com.example.smishingdetectionapp.UserProfileActivity">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/profile_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        app:srcCompat="@drawable/back_button"
        android:contentDescription="@string/back_button_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/profile_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:strokeColor="@color/cardview_shadow_start_color"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp"
                android:gravity="center_horizontal">

                <!-- Logo -->
                <ImageView
                    android:layout_width="123dp"
                    android:layout_height="104dp"
                    app:srcCompat="@drawable/new_logo"
                    android:contentDescription="@string/logo_description" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/user_profile_title"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/navy_blue" />

                <!-- Profile Picture -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="@color/white"
                    app:cardCornerRadius="70dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/navy_blue">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="30dp"
                        android:src="@drawable/account_user_svg"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/profile_picture_desc" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/cardview_shadow_start_color">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Full Name -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <EditText
                            android:id="@+id/et_value_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Moshadi Hansamali"
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:enabled="false"
                            android:background="@android:color/transparent"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/light_gray" />

                        <!-- Email -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Email"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/et_value_email"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="••••••••"
                                android:textSize="15sp"
                                android:textColor="@color/black"
                                android:enabled="false"
                                android:background="@android:color/transparent"/>

                            <ImageButton
                                android:id="@+id/btn_eye_email"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@android:color/transparent"
                                app:srcCompat="@drawable/ic_eye"
                                android:contentDescription="View Email"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/light_gray" />

                        <!-- Phone -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Phone Number"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/et_value_phone"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="••••••••"
                                android:textSize="15sp"
                                android:textColor="@color/black"
                                android:enabled="false"
                                android:background="@android:color/transparent"/>

                            <ImageButton
                                android:id="@+id/btn_eye_phone"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@android:color/transparent"
                                app:srcCompat="@drawable/ic_eye"
                                android:contentDescription="View Phone"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/light_gray" />

                        <!-- Address -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/address_label"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/et_value_address"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="••••••••"
                                android:textSize="15sp"
                                android:textColor="@color/black"
                                android:enabled="false"
                                android:background="@android:color/transparent"/>

                            <ImageButton
                                android:id="@+id/btn_eye_address"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@android:color/transparent"
                                app:srcCompat="@drawable/ic_eye"
                                android:contentDescription="View Address"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/edit_button"
                        android:textColor="@color/black"
                        android:backgroundTint="@color/light_blue"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/cardview_shadow_start_color"
                        app:strokeWidth="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_risk"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/view_risk_profile"
                        android:textColor="@color/black"
                        android:backgroundTint="@color/light_blue"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/cardview_shadow_start_color"
                        app:strokeWidth="2dp" />
                </LinearLayout>

                <!-- Reset PIN Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_pin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Reset PIN"
                    android:textColor="@color/black"
                    android:backgroundTint="@color/light_blue"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/cardview_shadow_start_color"
                    app:strokeWidth="2dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
