<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:context=".RiskProfileActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/risk_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/back_button_description"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back_button" />

            <!-- Logo -->
            <ImageView
                android:id="@+id/RiskLogo"
                android:layout_width="112dp"
                android:layout_height="106dp"
                android:layout_marginTop="20dp"
                android:contentDescription="Risk Profile Logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/risk_back"
                app:srcCompat="@drawable/new_logo" />

            <!-- Title -->
            <TextView
                android:id="@+id/RiskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Risk Profile"
                android:textAlignment="center"
                android:textColor="@color/navy_blue"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/RiskLogo" />

            <!-- Divider -->
            <View
                android:id="@+id/divider_risk"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/navy_blue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/RiskTitle" />

            <!-- Overall Risk Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_overall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="6dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_risk">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="8dp"
                        android:text="Overall Risk Score"
                        android:textAlignment="center"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/riskProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/risk_progress_bar" />

                    <TextView
                        android:id="@+id/tv_risk_score_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="0/100"
                        android:textColor="#374151"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tv_risk_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:paddingTop="8dp"
                        android:text="Risk Level: -"
                        android:textColor="#1F2937"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Breakdown Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_breakdown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="6dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_overall">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="12dp"
                        android:text="Breakdown"
                        android:textAlignment="center"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Login Attempts"
                        android:textColor="#374151"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/bar_login_attempts"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/risk_progress_bar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="PIN Resets"
                        android:textColor="#374151"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/bar_pin_resets"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/risk_progress_bar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Profile Completeness"
                        android:textColor="#374151"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/bar_profile_completeness"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/risk_progress_bar" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recommendations -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_recommendations"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="6dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_breakdown">

                <TextView
                    android:id="@+id/tv_recommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="6dp"
                    android:padding="20dp"
                    android:text="• Enable Two-Factor Authentication\n• Use a stronger PIN"
                    android:textColor="#374151"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Recent Activity -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_recent_activity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="6dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_recommendations">

                <TextView
                    android:id="@+id/tv_recent_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="6dp"
                    android:padding="20dp"
                    android:text="• 3 Logins this week\n• 1 PIN Reset\n• 0 Failed Attempts"
                    android:textColor="#374151"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Security Status -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_security"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#FFFFFF"
                android:elevation="6dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_recent_activity">

                <TextView
                    android:id="@+id/tv_security_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="6dp"
                    android:padding="20dp"
                    android:text="✅ PIN is set\n⚠️ No 2FA enabled\n✅ Profile details are complete"
                    android:textColor="#374151"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Button -->
            <Button
                android:id="@+id/btn_improve_security"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#2563EB"
                android:fontFamily="sans-serif-medium"
                android:text="Improve Security"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_security" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</RelativeLayout>
