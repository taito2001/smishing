<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/feedback_card_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:text="@string/thank_you_message"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/smish_text_primary"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnCloseThankYou"
        android:text="@string/close"
        android:backgroundTint="@color/smish_blue_dark"
        android:textColor="@color/smish_text_on_primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
