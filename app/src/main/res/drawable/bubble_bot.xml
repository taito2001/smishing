<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Use themed surface color instead of hard white -->
    <solid android:color="@color/smish_surface"/>

    <!-- Subtle border -->
    <stroke
        android:width="1dp"
        android:color="@color/smish_stroke"/>

    <!-- Rounded corners for consistency -->
    <corners android:radius="18dp"/>

    <!-- Padding -->
    <padding
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="12dp"/>
</shape>
